APP_NAME=videolibrary
APP_ENV=local
HTTP_ADDR=0.0.0.0:8080

POSTGRES_DSN=postgres://videolibrary:videolibrary@localhost:5432/videolibrary?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=0
POSTGRES_RETRY_TIMEOUT=30s
POSTGRES_CONNECT_TIMEOUT=5s
POSTGRES_MIGRATIONS_PATH=migrations

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

SEAWEEDFS_PUBLIC_URL=http://localhost:8888

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=
