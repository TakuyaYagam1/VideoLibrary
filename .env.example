APP_NAME=videolibrary
APP_ENV=local
FRONTEND_DOMAIN=example.com
BACKEND_DOMAIN=api.example.com
BACKEND_PORT=8080
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
ACME_EMAIL=admin@example.com
HTTP_READ_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_MAX_HEADER_BYTES=1048576

POSTGRES_DB=videolibrary
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=0
POSTGRES_RETRY_TIMEOUT=30s
POSTGRES_CONNECT_TIMEOUT=5s
POSTGRES_MIGRATIONS_PATH=migrations

REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10

CACHE_VIDEO_LIST_TTL=5m
HEALTH_CHECK_TIMEOUT=2s

SEAWEEDFS_DATA_DIR=/data
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_PORT=8888
SEAWEEDFS_FILES_DOMAIN=files.example.com
SEAWEEDFS_ADMIN_DOMAIN=seaweedfs.example.com
SEAWEEDFS_VIDEO_PREFIX=videos
SEAWEEDFS_ADMIN_PORT=23646
SEAWEEDFS_ADMIN_GRPC_PORT=33646
SEAWEEDFS_ADMIN_DATA_DIR=/data/admin
SEAWEEDFS_ADMIN_USER=admin
SEAWEEDFS_ADMIN_PASSWORD=
SEAWEEDFS_ADMIN_BASIC_AUTH_USER=admin
# Generate from SEAWEEDFS_ADMIN_PASSWORD for Caddy basic_auth:
# docker run --rm caddy:2.11.4-alpine caddy hash-password --plaintext 'your-password'
SEAWEEDFS_ADMIN_BASIC_AUTH_HASH=

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=
